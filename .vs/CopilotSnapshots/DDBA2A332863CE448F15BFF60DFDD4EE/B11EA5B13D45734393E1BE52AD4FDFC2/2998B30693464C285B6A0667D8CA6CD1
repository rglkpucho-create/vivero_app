@main_bp.route('/proveedores')
@login_required
def lista_proveedores():
    # Parámetro de búsqueda q y flag ajax para peticiones parciales
    query_str = request.args.get('q', '').strip()
    es_ajax = request.args.get('ajax') == '1'
    query = Proveedor.query
    if query_str:
        # Filtrar por varios campos usando OR y búsqueda case-insensitive
        query = query.filter(or_(
            Proveedor.razon_social.ilike(f'%{query_str}%'),
            Proveedor.nit_rut.ilike(f'%{query_str}%'),
            Proveedor.contacto_nombre.ilike(f'%{query_str}%')
        ))
    proveedores = query.order_by(Proveedor.razon_social).all()
    # Si es petición AJAX devolver solo el fragmento HTML para inyección
    if es_ajax:
        return render_template('parciales/items_proveedores.html', proveedores=proveedores)
    # Si no, devolver la página completa
    return render_template('lista_proveedores.html', proveedores=proveedores, search_query=query_str)


@main_bp.route('/proveedor/nuevo', methods=['GET', 'POST'])
@main_bp.route('/proveedor/editar/<int:proveedor_id>', methods=['GET', 'POST'])
@login_required
def nuevo_proveedor(proveedor_id=None):
    # Si proveedor_id se suministra, cargar proveedor para edición
    proveedor = None
    if proveedor_id:
        proveedor = Proveedor.query.get_or_404(proveedor_id)

    if request.method == 'POST':
        # Extraer campos del formulario
        razon_social = request.form.get('razon_social')
        nit_rut = request.form.get('nit_rut') or None 
        contacto = request.form.get('contacto_nombre')
        telefono = request.form.get('telefono')
        email = request.form.get('email')
        direccion = request.form.get('direccion')

        # Validación básica
        if not razon_social:
            flash('La Razón Social es obligatoria.', 'warning')
            return render_template('nuevo_proveedor.html', proveedor=proveedor)
        
        try:
            if proveedor:
                # Actualizar campos del proveedor existente
                proveedor.razon_social = razon_social
                proveedor.nit_rut = nit_rut
                proveedor.contacto_nombre = contacto
                # Nota: la asignación a nickname_field es confusa; se recomienda simplificar
                proveedor.telefono = nickname_field = telefono
                proveedor.email = email
                proveedor.direccion = direccion
                flash('Proveedor actualizado exitosamente.', 'success')
            else:
                # Crear nuevo proveedor (usa nickname_field si fue creado arriba, sino contacto)
                nuevo = Proveedor(
                    razon_social=razon_social, nit_rut=nit_rut, contacto_nombre=nickname_field if 'nickname_field' in locals() else contacto,
                    telefono=telefono, email=email, direccion=direccion
                )
                db.session.add(nuevo)
                flash('Proveedor registrado exitosamente.', 'success')
            # Guardar cambios en la base de datos
            db.session.commit()
            return redirect(url_for('main.lista_proveedores'))
        except Exception as e:
            # En caso de error revertir y mostrar mensaje
            db.session.rollback()
            flash(f'Error al guardar: {e}', 'danger')
            return render_template('nuevo_proveedor.html', proveedor=proveedor)

    # GET: mostrar formulario
    return render_template('nuevo_proveedor.html', proveedor=proveedor)


