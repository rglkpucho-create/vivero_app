@main_bp.route('/siembra/nueva', methods=['GET', 'POST'])
@login_required
def nuevo_lote(): # Endpoint renombrado para coincidir con templates y evitar BuildError
    # Preparar datos para el formulario de siembra (sedes y especies)
    sedes = Sede.query.order_by(Sede.nombre).all()
    especies = Especie.query.order_by(Especie.nombre_comun).all()
    
    if request.method == 'POST':
        try:
            sede_id = request.form.get('sede_id')
            especie_id = request.form.get('especie_id')
            # Capturamos la ubicación/sector desde el formulario
            sector_seleccionado = request.form.get('ubicacion')
            
            # Validar campos obligatorios
            if not sede_id or not especie_id or not sector_seleccionado:
                flash('Por favor selecciona Sede, Sector y Especie.', 'warning')
                return render_template('nueva_siembra.html', sedes=sedes, especies=especies, siembra=None)
            
            # Generar código de lote único
            codigo = f"SMB-{int(datetime.now().timestamp())}"
            cantidad = int(request.form.get('cantidad'))
            
            # Crear instancia de LoteProduccion con los datos de siembra
            nuevo_lote_obj = LoteProduccion(
                codigo_lote=codigo,
                especie_id=int(especie_id),
                sede_id=int(sede_id),
                cantidad_sembrada=cantidad,
                cantidad_actual=cantidad,
                fecha_siembra=datetime.strptime(request.form.get('fecha_siembra'), '%Y-%m-%d').date(),
                ubicacion=sector_seleccionado, # Guardar sector/ubicación
                estado='En Crecimiento',
                costo_total=0.0
            )
            
            db.session.add(nuevo_lote_obj)
            db.session.commit()
            flash('Siembra registrada con éxito.', 'success')
            return redirect(url_for('main.lista_siembras'))
            
        except Exception as e:
            db.session.rollback()
            flash(f'Error al registrar siembra: {e}', 'danger')
            
    return render_template('nueva_siembra.html', sedes=sedes, especies=especies, siembra=None)


@main_bp.route('/produccion/lotes')
@login_required
def lista_lotes():
    # Buscar/filtrar lotes por código, especie, estado o sede
    query_str = request.args.get('q', '').strip()
    estado_filtro = request.args.get('estado')
    sede_filtro = request.args.get('sede')
    sedes = Sede.query.order_by(Sede.nombre).all()
    
    # Unir tablas para permitir búsquedas por campos relacionados
    query = LoteProduccion.query.join(Especie).outerjoin(Sede)
    if query_str:
        query = query.filter(or_(LoteProduccion.codigo_lote.ilike(f'%{query_str}%'), Especie.nombre_comun.ilike(f'%{query_str}%')))
    
    # KPI: conteos generales antes/aplicar filtros
    kpi_total = query.count()
    kpi_activos = query.filter(LoteProduccion.estado == 'En Crecimiento').count()
    kpi_finalizados = query.filter(LoteProduccion.estado != 'En Crecimiento').count()
    
    # Aplicar filtros si están presentes
    if estado_filtro:
        query = query.filter(LoteProduccion.estado == estado_filtro)
    if sede_filtro and sede_filtro.isdigit():
        query = query.filter(LoteProduccion.sede_id == int(sede_filtro))
    
    lotes = query.order_by(LoteProduccion.fecha_siembra.desc()).all()
    return render_template('produccion/lista_lotes.html', lotes=lotes, sedes=sedes, today=datetime.utcnow().date(),
                           kpi_total=kpi_total, kpi_activos=kpi_activos, kpi_finalizados=kpi_finalizados)


