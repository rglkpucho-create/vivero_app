"""
Módulo de vistas (routes) de la aplicación.

Contiene las rutas agrupadas en el blueprint `main_bp`.
Cada ruta maneja peticiones HTTP, valida datos de entrada,
realiza consultas/operaciones con la base de datos usando SQLAlchemy
y renderiza plantillas Jinja2 para la respuesta.

Comentarios en español explican la intención y pasos clave dentro
de cada manejador para facilitar el entendimiento del flujo.
"""

# Importaciones de Flask y utilidades
from flask import Blueprint, render_template, redirect, url_for, flash, request, jsonify
# Flask-Login: manejo de sesiones y control de acceso
from flask_login import login_user, logout_user, login_required, current_user
# or_ para combinar condiciones en consultas SQLAlchemy
from sqlalchemy import or_
# Importar modelos usados en las vistas (representan tablas de la BD)
from .models import (
    Usuario, Rol, Proveedor, Insumo, UnidadMedida, 
    PedidoCompra, DetallePedidoCompra, LoteInsumo, MovimientoInventario,
    Especie, LoteProduccion, LaborCampo, ConsumoInsumo,
    Cliente, Venta, DetalleVenta, Sede
)
# Instancia de la base de datos (SQLAlchemy)
from .extensions import db
# Para manejo de fechas y timestamps
from datetime import datetime

# Definición del blueprint que agrupa estas rutas
main_bp = Blueprint('main', __name__)

