# 1. RUTAS PÚBLICAS Y AUTENTICACIÓN
# ==================================================

@main_bp.route('/')
def home():
    # Ruta pública que muestra la página de inicio (index.html)
    return render_template('index.html')

@main_bp.route('/registro', methods=['GET', 'POST'])
def registro():
    # Si el usuario ya está autenticado, redirigimos a la home
    if current_user.is_authenticated:
        return redirect(url_for('main.home'))

    # Si no existen roles en la BD, crear roles iniciales (una sola vez)
    if not Rol.query.first():
        try:
            roles_iniciales = [Rol(nombre='Administrador'), Rol(nombre='Trabajador'), Rol(nombre='Agrónomo'), Rol(nombre='Vendedor')]
            db.session.add_all(roles_iniciales)
            db.session.commit()
        except:
            # En caso de error al crear roles, hacer rollback
            db.session.rollback()

    # Si la petición es POST procesamos el formulario de registro
    if request.method == 'POST':
        nombre = request.form.get('nombre')  # campo nombre del formulario
        email = request.form.get('email')    # campo email
        password = request.form.get('password')
        telefono = request.form.get('telefono')
        rol_nombre = request.form.get('rol') 

        # Validación sencilla: campos obligatorios
        if not nombre or not email or not password:
            flash('Por favor llena los campos obligatorios.', 'warning')
            return render_template('registro.html')

        # Verificar que el email no esté registrado
        if Usuario.query.filter_by(email=email).first():
            flash('El correo ya está registrado.', 'warning')
            return render_template('registro.html')

        # Obtener el rol seleccionado; si no existe usar 'Trabajador' por defecto
        rol_obj = Rol.query.filter_by(nombre=rol_nombre).first()
        if not rol_obj:
            rol_obj = Rol.query.filter_by(nombre='Trabajador').first()

        try:
            # Crear instancia de Usuario (sin guardar contraseña en texto plano)
            nuevo_usuario = Usuario(
                nombre_completo=nombre, email=email, telefono=telefono,
                rol_id=rol_obj.id if rol_obj else None, fecha_registro=datetime.utcnow()
            )
            # Hashear y asignar contraseña (método definido en models.py)
            nuevo_usuario.set_password(password)
            db.session.add(nuevo_usuario)
            db.session.commit()
            flash('¡Cuenta creada! Por favor inicia sesión.', 'success')
            return redirect(url_for('main.login'))
        except Exception as e:
            # En caso de error revertir la transacción y mostrar mensaje
            db.session.rollback()
            flash(f'Error al registrar: {e}', 'danger')

    # Obtener lista de roles para mostrar en el formulario (si falla devolver lista vacía)
    try:
        roles = Rol.query.all()
    except:
        roles = []
    return render_template('registro.html', roles=roles)


@main_bp.route('/login', methods=['GET', 'POST'])
def login():
    # Si ya hay sesión, ir al dashboard
    if current_user.is_authenticated:
        return redirect(url_for('main.dashboard'))

    # Procesar formulario de login
    if request.method == 'POST':
        email = request.form.get('email')
        password = request.form.get('password')
        # Buscar usuario por email
        user = Usuario.query.filter_by(email=email).first()
        # Verificar contraseña usando el método del modelo
        if user and user.check_password(password):
            # Iniciar sesión mediante Flask-Login
            login_user(user)
            flash(f'Bienvenido, {user.nombre_completo}', 'success')
            return redirect(url_for('main.dashboard'))
        else:
            flash('Email o contraseña incorrectos.', 'danger')
    # Mostrar plantilla de login
    return render_template('login.html')


@main_bp.route('/logout')
@login_required
def logout():
    # Cerrar sesión del usuario actual
    logout_user()
    return redirect(url_for('main.home'))


@main_bp.route('/dashboard')
@login_required
def dashboard():
    # Recopilar métricas y listas para el tablero principal
    total_insumos = Insumo.query.count()  # número total de insumos
    total_proveedores = Proveedor.query.count()  # número total de proveedores
    # Insumos cuyo stock actual está por debajo o igual al mínimo
    insumos_alerta = Insumo.query.filter(Insumo.cantidad_actual <= Insumo.stock_minimo).all()
    pedidos_pendientes = PedidoCompra.query.filter_by(estado='Solicitado').count()
    lotes_activos = LoteProduccion.query.filter_by(estado='En Crecimiento').count()
    # Calcular fecha de inicio del mes para filtrar ventas del mes
    fecha_inicio_mes = datetime.now().replace(day=1, hour=0, minute=0, second=0, microsecond=0)
    ventas_mes = Venta.query.filter(Venta.fecha >= fecha_inicio_mes).count()
    especies = Especie.query.all()
    proveedores = Proveedor.query.order_by(Proveedor.razon_social).all()
    unidades = UnidadMedida.query.all()
    
    # Si no hay unidades definidas, insertar algunas por defecto
    if not unidades:
        try:
            db.session.add_all([UnidadMedida(nombre='Unidad', abreviatura='ud'), UnidadMedida(nombre='Kilogramo', abreviatura='kg')])
            db.session.commit()
            unidades = UnidadMedida.query.all()
        except:
            # No hacer nada si falla la inserción por defecto
            pass

    # Renderizar la plantilla del dashboard pasando todas las variables necesarias
    return render_template('dashboard.html',
                           total_insumos=total_insumos,
                           total_proveedores=total_proveedores,
                           insumos_alerta=insumos_alerta,
                           pedidos_pendientes=pedidos_pendientes,
                           lotes_activos=lotes_activos,
                           ventas_mes=ventas_mes,
                           especies=especies,
                           proveedores=proveedores,
                           unidades=unidades)


