@main_bp.route('/insumos')
@login_required
def lista_insumos():
    # Buscar insumos por nombre o tipo y/o mostrar solo alertas de stock
    query_str = request.args.get('q', '').strip()
    mostrar_alertas = request.args.get('alertas') == '1'
    query = Insumo.query
    if query_str:
        query = query.filter(or_(
            Insumo.nombre.ilike(f'%{query_str}%'),
            Insumo.tipo.ilike(f'%{query_str}%')
        ))
    if mostrar_alertas:
        # Filtrar insumos con cantidad_actual menor o igual al stock_minimo
        query = query.filter(Insumo.cantidad_actual <= Insumo.stock_minimo)
    insumos = query.all()
    return render_template('lista_insumos.html', insumos=insumos, search_query=query_str)


@main_bp.route('/insumo/nuevo', methods=['GET', 'POST'])
@main_bp.route('/insumo/editar/<int:insumo_id>', methods=['GET', 'POST'])
@login_required
def nuevo_insumo(insumo_id=None):
    # Asegurar que existan unidades de medida por defecto en la BD
    if not UnidadMedida.query.first():
        try:
            unidades = [UnidadMedida(nombre='Kilogramo', abreviatura='kg'), UnidadMedida(nombre='Litro', abreviatura='L')]
            db.session.add_all(unidades)
            db.session.commit()
        except:
            db.session.rollback()

    unidades = UnidadMedida.query.all()
    insumo = Insumo.query.get_or_404(insumo_id) if insumo_id else None

    if request.method == 'POST':
        nombre = request.form.get('nombre')
        # Validación: nombre obligatorio
        if not nombre:
            flash('El nombre es obligatorio.', 'warning')
            return render_template('nuevo_insumo.html', unidades=unidades, insumo=insumo)
        try:
            if insumo:
                # Actualizar campos del insumo existente
                insumo.nombre = nombre
                insumo.tipo = request.form.get('tipo')
