@main_bp.route('/configuracion/sedes')
@login_required
def lista_sedes():
    # Listar sedes y calcular cantidad de lotes activos por sede
    sedes = Sede.query.order_by(Sede.nombre).all()
    for s in sedes:
        s.lotes_activos = LoteProduccion.query.filter_by(sede_id=s.id, estado='En Crecimiento').count()
    return render_template('lista_sedes.html', sedes=sedes)


@main_bp.route('/configuracion/sede/nueva', methods=['GET', 'POST'])
@main_bp.route('/configuracion/sede/editar/<int:sede_id>', methods=['GET', 'POST'])
@login_required
def nueva_sede(sede_id=None):
    # Crear o editar una sede
    sede = Sede.query.get_or_404(sede_id) if sede_id else None
    if request.method == 'POST':
        nombre = request.form.get('nombre')
        if not nombre:
            flash('El nombre es obligatorio.', 'warning')
            return render_template('nueva_sede.html', sede=sede)
        try:
            if sede:
                # Actualizar sede existente
                sede.nombre = nombre
                sede.tipo = request.form.get('tipo')
                sede.ubicacion_geo = request.form.get('ubicacion_geo')
            else:
                # Crear nueva sede
                db.session.add(Sede(nombre=nombre, tipo=request.form.get('tipo'), ubicacion_geo=request.form.get('ubicacion_geo')))
            db.session.commit()
            return redirect(url_for('main.lista_sedes'))
        except Exception as e:
            db.session.rollback()
            flash(f'Error al guardar sede: {e}', 'danger')
    return render_template('nueva_sede.html', sede=sede)


@main_bp.route('/configuracion/sede/eliminar/<int:sede_id>', methods=['POST'])
@login_required
def eliminar_sede(sede_id):
    # Eliminar sede si no tiene lotes asociados
    sede = Sede.query.get_or_404(sede_id)
    if LoteProduccion.query.filter_by(sede_id=sede.id).count() > 0:
        flash('No se puede eliminar una sede con lotes asociados.', 'warning')
    else:
        db.session.delete(sede)
        db.session.commit()
        flash('Sede eliminada.', 'success')
    return redirect(url_for('main.lista_sedes'))